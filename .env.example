# Copy this file to .env when the project needs local configuration.
# Do not put real secrets in this example file.

# The Odds API key is used to fetch today's MLB game schedule.
ODDS_API_KEY=

# Reserved for future fantasy data integrations.
FANTASY_DATA_API_KEY=

# ESPN Fantasy Baseball integration.
# Keep real cookie values only in your local .env file.
ESPN_LEAGUE_ID=
ESPN_TEAM_ID=
ESPN_SEASON_YEAR=
ESPN_SWID=
ESPN_S2=
